# OpenRouter (agent)
OPENROUTER_API_KEY=

# CRM source: auto | mock | hubspot
# auto = HubSpot when HUBSPOT_ACCESS_TOKEN is set, otherwise mock
CRM_PROVIDER=auto

# HubSpot private app token (read-only scopes)
HUBSPOT_ACCESS_TOKEN=

# Real HubSpot company id for agent/live verification (Northwind Analytics)
# HUBSPOT_TEST_COMPANY_ID=333055649511

# Optional HubSpot property overrides
# HUBSPOT_PROP_RENEWAL=accountpulse_renewal_date
# HUBSPOT_PROP_PLAN_TIER=type
# HUBSPOT_PROP_CONTRACT_STATUS=accountpulse_contract_status

# Force CRM outage for testing
# CRM_FORCE_ERROR=1
