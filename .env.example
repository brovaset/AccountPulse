# Model provider: ollama (default, free/local) | openrouter
MODEL_PROVIDER=ollama

# Ollama (default local). Prefer 1.5b/3b on 8GB laptops; 7b needs ~16GB+ RAM.
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_MAX_TOKENS=1536
# OLLAMA_NUM_CTX=4096
# OLLAMA_API_BASE=http://localhost:11434

# OpenRouter (only when MODEL_PROVIDER=openrouter)
OPENROUTER_API_KEY=

# CRM source: auto | mock | hubspot
# auto = HubSpot when HUBSPOT_ACCESS_TOKEN is set, otherwise mock
CRM_PROVIDER=auto

# HubSpot private app token (read-only scopes)
HUBSPOT_ACCESS_TOKEN=

# Real HubSpot company id for agent/live verification (Northwind Analytics)
# HUBSPOT_TEST_COMPANY_ID=333055649511
# Map mock demo ids → HubSpot company ids for joint live demos
# HUBSPOT_ACCOUNT_ID_MAP={"acc_001":"333055649511","acc_002":"332906103502","acc_003":"333057467115"}

# Optional HubSpot property overrides
# HUBSPOT_PROP_RENEWAL=accountpulse_renewal_date
# HUBSPOT_PROP_PLAN_TIER=type
# HUBSPOT_PROP_CONTRACT_STATUS=accountpulse_contract_status

# Force CRM outage for testing
# CRM_FORCE_ERROR=1

# ---------------------------------------------------------------------------
# Phase 3 live connectors (optional). Default remains mock when unset.
# Salesforce CRM is deferred.
# ---------------------------------------------------------------------------

# Support: auto | mock | zendesk
SUPPORT_PROVIDER=auto
# ZENDESK_SUBDOMAIN=your-subdomain
# ZENDESK_EMAIL=agent@example.com
# ZENDESK_API_TOKEN=
# Optional JSON map: AccountPulse/HubSpot id → Zendesk organization id
# (preferred when orgs do not have external_id set)
# ZENDESK_ORG_ID_MAP={"acc_001":"51509923853716","333055649511":"51509923853716"}
# Optional JSON map: AccountPulse/HubSpot id → Zendesk organization external_id
# ZENDESK_EXTERNAL_ID_MAP={"acc_001":"acc_001","333055649511":"acc_001"}
# SUPPORT_FORCE_ERROR=1

# Product usage: auto | mock | posthog | gainsight
# Prefer PostHog (free cloud tier). Gainsight remains optional if you have access.
USAGE_PROVIDER=auto
# POSTHOG_HOST=https://us.posthog.com
# Project API key (phc_...) — used to *send* events
# POSTHOG_PROJECT_API_KEY=
# POSTHOG_PROJECT_ID=
# Personal API key — used to *query* events (Query Read permission)
# POSTHOG_PERSONAL_API_KEY=
# Event used as activity proxy (default $pageview)
# POSTHOG_EVENT=$pageview
# HogQL filter template; {account} is substituted from POSTHOG_ACCOUNT_MAP
# POSTHOG_FILTER_TEMPLATE=toString(properties.account_id) = '{account}'
# POSTHOG_ACCOUNT_MAP={"acc_001":"acc_001","333055649511":"acc_001"}
# Optional paid Gainsight path:
# GAINSIGHT_BASE_URL=https://your-tenant.gainsightcloud.com
# GAINSIGHT_ACCESS_KEY=
# GAINSIGHT_COMPANY_ID_MAP={"acc_001":"Northwind Analytics"}
# USAGE_FORCE_ERROR=1

# Communications: auto | mock | gmail
COMMUNICATION_PROVIDER=auto
# Google Cloud OAuth Desktop client (Gmail API enabled)
# GMAIL_CLIENT_ID=....apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=
# Filled by: python scripts/gmail_oauth_setup.py
# GMAIL_ACCESS_TOKEN=
# GMAIL_REFRESH_TOKEN=
# Optional JSON map: account id → Gmail search term
# GMAIL_QUERY_MAP={"acc_001":"in:inbox","333055649511":"in:inbox"}
# GMAIL_SEARCH_TEMPLATE=newer_than:30d {term}
# COMMUNICATION_FORCE_ERROR=1
